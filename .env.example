# ── Decart ──────────────────────────────────────────────────────────────
# Permanent API key (dct_...). Lives ONLY in the sidecar; never shipped to a page.
# The sidecar mints short-lived ek_ client tokens from it per hijack job.
DECART_API_KEY=dct_replace_me

# ── Streamlabs ──────────────────────────────────────────────────────────
# Socket API token: Streamlabs Dashboard → Account Settings → API Settings →
# API Tokens → "Your Socket API Token". Enables the real donation trigger.
# Leave blank to run with only the fake-tip dev trigger.
STREAMLABS_SOCKET_TOKEN=

# ── OBS ─────────────────────────────────────────────────────────────────
# obs-websocket (OBS → Tools → WebSocket Server Settings). Blank password OK
# if you disabled auth. The router page connects to this.
OBS_WS_URL=ws://127.0.0.1:4455
OBS_WS_PASSWORD=
# Scene + Browser Source that displays the AI viewer page (toggled on/off).
OBS_SCENE=Scene
OBS_SOURCE=AI Hijack

# ── Ports ───────────────────────────────────────────────────────────────
SIDECAR_PORT=7712
WEB_PORT=5173
